generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  RH
  GERENTE
  FUNCIONARIO
}

enum EvaluationStatus {
  DRAFT
  COMPLETED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(RH)
  createdAt DateTime @default(now())

  employee         Employee?      @relation("UserEmployee")
  evaluations      Evaluation[]   @relation("EvaluatorEvaluations")
  managedTeams     TeamManager[]
  teamMemberships  TeamMember[]
}

model Employee {
  id         String   @id @default(uuid())
  name       String
  position   String
  department String
  active     Boolean  @default(true)
  userId     String?  @unique
  createdAt  DateTime @default(now())

  user            User?        @relation("UserEmployee", fields: [userId], references: [id], onDelete: SetNull)
  evaluations     Evaluation[]
  teamMemberships TeamMember[]

  @@index([userId])
}

model Team {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members  TeamMember[]
  managers TeamManager[]
}

model TeamMember {
  id         String   @id @default(uuid())
  teamId     String
  employeeId String
  userId     String?
  createdAt  DateTime @default(now())

  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([teamId, employeeId])
  @@index([teamId])
  @@index([employeeId])
  @@index([userId])
}

model TeamManager {
  id        String   @id @default(uuid())
  teamId    String
  managerId String
  createdAt DateTime @default(now())

  team    Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  manager User @relation(fields: [managerId], references: [id], onDelete: Cascade)

  @@unique([teamId, managerId])
  @@index([teamId])
  @@index([managerId])
}

model EvaluationTemplate {
  id        String   @id @default(uuid())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  categories  EvaluationCategory[]
  evaluations Evaluation[]
}

model EvaluationCategory {
  id         String @id @default(uuid())
  templateId String
  name       String
  weight     Float
  order      Int

  template         EvaluationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  questions        EvaluationQuestion[]
  categoryComments CategoryComment[]

  @@index([templateId])
}

model EvaluationQuestion {
  id         String @id @default(uuid())
  categoryId String
  text       String
  order      Int

  category EvaluationCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  answers  EvaluationAnswer[]

  @@index([categoryId])
}

model Evaluation {
  id                String           @id @default(uuid())
  employeeId        String
  templateId        String
  evaluatorId       String
  period            String
  evaluatedAt       DateTime         @default(now())
  status            EvaluationStatus @default(DRAFT)
  isAutoEvaluation  Boolean          @default(false)
  finalScore        Float?
  classification    String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  employee         Employee           @relation(fields: [employeeId], references: [id])
  template         EvaluationTemplate @relation(fields: [templateId], references: [id])
  evaluator        User               @relation("EvaluatorEvaluations", fields: [evaluatorId], references: [id])
  answers          EvaluationAnswer[]
  categoryComments CategoryComment[]
  finalFeedback    FinalFeedback?

  @@index([employeeId])
  @@index([templateId])
  @@index([evaluatorId])
  @@index([status])
  @@index([isAutoEvaluation])
}

model EvaluationAnswer {
  id           String  @id @default(uuid())
  evaluationId String
  questionId   String
  score        Int
  comment      String?

  evaluation Evaluation         @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  question   EvaluationQuestion @relation(fields: [questionId], references: [id])

  @@unique([evaluationId, questionId])
  @@index([evaluationId])
}

model CategoryComment {
  id           String @id @default(uuid())
  evaluationId String
  categoryId   String
  comment      String

  evaluation Evaluation         @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  category   EvaluationCategory @relation(fields: [categoryId], references: [id])

  @@unique([evaluationId, categoryId])
}

model FinalFeedback {
  id              String @id @default(uuid())
  evaluationId    String @unique
  strengths       String
  improvements    String
  recommendations String

  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
}
