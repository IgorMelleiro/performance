# Neon PostgreSQL (produção)
# Cole a connection string do console Neon (Connection details → psql)
# Adicione sslmode=require se não vier na URL
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# Não commitar este arquivo — já está no .gitignore via .env
JWT_SECRET=""
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="https://seu-app.vercel.app"
PORT=3001
